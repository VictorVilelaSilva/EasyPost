# Firebase Admin SDK (verificação de ID token)
# Obtenha em: Firebase Console → Configurações do projeto → Contas de serviço → Gerar nova chave privada
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# OpenAI (geração de imagens)
OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_SECONDS=300

# CORS / frontend
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
FRONTEND_URL=http://localhost:3000

# PokéAPI proxy
POKEMON_API_BASE_URL=https://pokeapi.co/api/v2
POKEMON_CACHE_TTL_SECONDS=86400

ENVIRONMENT=development
